{
  "$schema": "https://corp.internal/design-tokens/schema/v1",
  "$description": "Corporate Design System — Single Source of Truth v1.0.0",

  "color": {
    "brand": {
      "blue":         { "value": "#004b8d", "$type": "color", "$description": "Azul corporativo principal" },
      "blue-dark":    { "value": "#003668", "$type": "color", "$description": "Azul oscuro — sidebar" },
      "blue-mid":     { "value": "#0062b8", "$type": "color", "$description": "Azul medio — hover" },
      "blue-light":   { "value": "#e8f0f9", "$type": "color", "$description": "Azul suave — backgrounds" },
      "green":        { "value": "#039f61", "$type": "color", "$description": "Verde corporativo" },
      "green-dark":   { "value": "#027a4a", "$type": "color", "$description": "Verde oscuro" },
      "green-light":  { "value": "#e6f7f0", "$type": "color", "$description": "Verde suave" },
      "yellow":       { "value": "#ffd200", "$type": "color", "$description": "Amarillo corporativo" },
      "yellow-dark":  { "value": "#92640b", "$type": "color", "$description": "Amarillo texto oscuro" },
      "yellow-light": { "value": "#fff8d6", "$type": "color", "$description": "Amarillo suave" },
      "white":        { "value": "#ffffff", "$type": "color" }
    },
    "neutral": {
      "50":  { "value": "#f8fafc", "$type": "color" },
      "100": { "value": "#f1f5f9", "$type": "color" },
      "200": { "value": "#e2e8f0", "$type": "color" },
      "300": { "value": "#cbd5e1", "$type": "color" },
      "400": { "value": "#94a3b8", "$type": "color" },
      "500": { "value": "#64748b", "$type": "color" },
      "600": { "value": "#475569", "$type": "color" },
      "700": { "value": "#334155", "$type": "color" },
      "800": { "value": "#1e293b", "$type": "color" },
      "900": { "value": "#0f172a", "$type": "color" }
    },
    "semantic": {
      "danger":        { "value": "#ef4444", "$type": "color" },
      "danger-light":  { "value": "#fef2f2", "$type": "color" },
      "warning":       { "value": "#f59e0b", "$type": "color" },
      "warning-light": { "value": "#fffbeb", "$type": "color" },
      "info":          { "value": "#0ea5e9", "$type": "color" },
      "info-light":    { "value": "#f0f9ff", "$type": "color" },
      "success":       { "value": "#039f61", "$type": "color" },
      "success-light": { "value": "#e6f7f0", "$type": "color" }
    }
  },

  "typography": {
    "font-family": {
      "display": { "value": "'Montserrat', sans-serif", "$type": "fontFamily" },
      "body":     { "value": "'Lato', sans-serif",      "$type": "fontFamily" },
      "mono":     { "value": "'Courier New', monospace", "$type": "fontFamily" }
    },
    "font-size": {
      "xs":   { "value": "0.65rem",  "$type": "fontSize" },
      "sm":   { "value": "0.75rem",  "$type": "fontSize" },
      "base": { "value": "0.875rem", "$type": "fontSize" },
      "md":   { "value": "1rem",     "$type": "fontSize" },
      "lg":   { "value": "1.125rem", "$type": "fontSize" },
      "xl":   { "value": "1.25rem",  "$type": "fontSize" },
      "2xl":  { "value": "1.5rem",   "$type": "fontSize" },
      "3xl":  { "value": "1.875rem", "$type": "fontSize" }
    },
    "font-weight": {
      "light":    { "value": "300", "$type": "fontWeight" },
      "regular":  { "value": "400", "$type": "fontWeight" },
      "medium":   { "value": "600", "$type": "fontWeight" },
      "bold":     { "value": "700", "$type": "fontWeight" },
      "extrabold":{ "value": "800", "$type": "fontWeight" }
    },
    "line-height": {
      "tight":  { "value": "1.1",  "$type": "lineHeight" },
      "snug":   { "value": "1.3",  "$type": "lineHeight" },
      "normal": { "value": "1.5",  "$type": "lineHeight" },
      "relaxed":{ "value": "1.65", "$type": "lineHeight" }
    }
  },

  "spacing": {
    "xs":  { "value": "4px",  "$type": "spacing" },
    "sm":  { "value": "8px",  "$type": "spacing" },
    "md":  { "value": "16px", "$type": "spacing" },
    "lg":  { "value": "24px", "$type": "spacing" },
    "xl":  { "value": "32px", "$type": "spacing" },
    "2xl": { "value": "48px", "$type": "spacing" },
    "3xl": { "value": "64px", "$type": "spacing" }
  },

  "border-radius": {
    "sm":   { "value": "8px",    "$type": "borderRadius" },
    "md":   { "value": "12px",   "$type": "borderRadius" },
    "lg":   { "value": "16px",   "$type": "borderRadius" },
    "xl":   { "value": "24px",   "$type": "borderRadius" },
    "pill": { "value": "999px",  "$type": "borderRadius" }
  },

  "shadow": {
    "xs": { "value": "0 1px 3px rgba(0,0,0,0.06)",    "$type": "shadow" },
    "sm": { "value": "0 2px 8px rgba(0,0,0,0.07)",    "$type": "shadow" },
    "md": { "value": "0 8px 28px rgba(0,0,0,0.10)",   "$type": "shadow" },
    "lg": { "value": "0 20px 60px rgba(0,0,0,0.14)",  "$type": "shadow" }
  },

  "transition": {
    "fast":   { "value": "0.15s cubic-bezier(.22,1,.36,1)", "$type": "transition" },
    "base":   { "value": "0.25s cubic-bezier(.22,1,.36,1)", "$type": "transition" },
    "slow":   { "value": "0.4s  cubic-bezier(.22,1,.36,1)", "$type": "transition" }
  },

  "layout": {
    "sidebar-width": { "value": "260px", "$type": "dimension" },
    "topbar-height": { "value": "64px",  "$type": "dimension" }
  },

  "z-index": {
    "dropdown": { "value": "1000", "$type": "other" },
    "sticky":   { "value": "1020", "$type": "other" },
    "modal":    { "value": "1050", "$type": "other" },
    "toast":    { "value": "9999", "$type": "other" }
  }
}
