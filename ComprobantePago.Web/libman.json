    {
      "library": "sweetalert2@11",
      "destination": "wwwroot/lib/sweetalert2/"
    },
    {
      "library": "bootstrap-icons@1.11.3",
      "destination": "wwwroot/lib/bootstrap-icons/"
    },
    {
      "library": "datatables.net@1.13.8",
      "destination": "wwwroot/lib/datatables.net/"
