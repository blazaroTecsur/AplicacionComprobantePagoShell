@* Views/Comprobante/_DetalleComprobante.cshtml *@

<!-- ══════════════════════════════════════════
     SECCIÓN: Encabezado
══════════════════════════════════════════ -->
<div class="seccion-panel">
    <div class="seccion-header">
        <strong>Encabezado</strong>
    </div>
    <div class="seccion-body">

        <!-- Fila 1: Folio, RUC, Razón Social -->
        <div class="row g-2 mb-2">
            <div class="col-md-2">
                <label class="form-label">Folio</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtFolio" name="txtFolio" readonly
                       style="background-color:#5cb85c; color:white; font-weight:bold;" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Nro. Doc. Identidad</label>
                <div class="input-group input-group-sm">
                    <input class="form-control" type="text"
                           id="txtNumeroDocumentoIdentidad" readonly />
                    <input type="hidden" id="hblCreditoFiscal" />
                    <input type="hidden" id="txtFechaProveedorEmiteElectronicas" />
                    <input type="hidden" id="txtPeriodoAbierto" />
                    <input type="hidden" id="txtTipoDocumentoIdentidad" />
                    <input type="hidden" id="hdnEmpleadoCodigo" />
                    <input type="hidden" id="hdnEmpleadoNombre" />
                    <button class="btn btn-outline-secondary" type="button"
                            id="btnBuscarProveedorPrincipal" disabled>
                        ...
                    </button>
                </div>
                <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="chkEsEmpleado" />
                    <label class="form-check-label small" for="chkEsEmpleado">¿Es empleado?</label>
                </div>
            </div>
            <div class="col-md-3 d-none" id="divSelectorEmpleado">
                <label class="form-label">Empleado</label>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" id="txtEmpleadoDisplay"
                           placeholder="Buscar por código o nombre..." readonly />
                    <button class="btn btn-outline-secondary" type="button" id="btnBuscarEmpleado">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label">Razón Social</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtRazonSocial" readonly />
            </div>
        </div>

        <!-- Fila 2: Tipo Comprobante, Tipo SUNAT, Serie, Número -->
        <div class="row g-2 mb-2">
            <div class="col-md-2">
                <label class="form-label">Tipo Comprobante</label>
                <select class="form-select form-select-sm"
                        id="ddlTipoDocumento" disabled></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Tipo SUNAT</label>
                <select class="form-select form-select-sm"
                        id="ddlTipoSunat" disabled></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Serie</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtSerie" readonly />
            </div>
            <div class="col-md-2">
                <label class="form-label">Número</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtNumero" readonly />
            </div>
        </div>

        <!-- Fila 3: Fechas, Moneda, Tasa Cambio -->
        <div class="row g-2 mb-2">
            <div class="col-md-2">
                <label class="form-label">Fecha Emisión</label>
                <input class="form-control form-control-sm" type="date"
                       id="txtFechaEmision" placeholder="dd/mm/yyyy" disabled />
            </div>
            <div class="col-md-2">
                <label class="form-label">Fecha Recepción</label>
                <input class="form-control form-control-sm" type="date"
                       id="txtFechaRecepcion" placeholder="dd/mm/yyyy" disabled />
            </div>
            <div class="col-md-2">
                <label class="form-label">Moneda</label>
                <select class="form-select form-select-sm"
                        id="ddlMoneda" disabled></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Tasa de Cambio</label>
                <input class="form-control form-control-sm text-end" type="text"
                       id="txtTasaCambio" readonly />
            </div>
        </div>

        <!-- Fila 4: CR, Lugar Pago, Trámite Pago -->
        <div class="row g-2 mb-2">
            <div class="col-md-3 d-none">
                <label class="form-label">Centro Responsabilidad</label>
                <div class="input-group input-group-sm">
                    <input class="form-control" type="text" id="txtCR" readonly />
                    <button class="btn btn-outline-secondary" type="button"
                            id="btnBuscarCRPrincipal" disabled>
                        ...
                    </button>
                </div>
            </div>
            <div class="col-md-3 d-none">
                <label class="form-label">&nbsp;</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtDesCR" readonly />
            </div>
            <div class="col-md-2">
                <label class="form-label">Lugar de Pago</label>
                <select class="form-select form-select-sm"
                        id="dldLugarPago" disabled></select>
            </div>
            <div class="col-md-2 d-none" id="panelTramPago">
                <label class="form-label">Trámite de Pago</label>
                <select class="form-select form-select-sm"
                        id="dldTramPago" disabled></select>
            </div>
            <div class="col-md-2 d-none" id="panelTipoBoleto">
                <label class="form-label">Tipo Boleto</label>
                <select class="form-select form-select-sm"
                        id="ddlTipoBoleto" disabled></select>
            </div>
            <div class="col-md-2 d-none" id="panelTipoRenta">
                <label class="form-label">Tipo Renta</label>
                <select class="form-select form-select-sm"
                        id="ddlTipoRenta" disabled></select>
            </div>
        </div>

        <!-- Fila 5: Plazo, Fecha Vencimiento -->
        <div class="row g-2 mb-2">
            <div class="col-md-2" id="panelPlazoPago">
                <label class="form-label">Plazo de Pago</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtPlazoPago" />
            </div>
            <div class="col-md-2 d-none" id="panelFechaVencimiento">
                <label class="form-label">Fecha Vencimiento</label>
                <input class="form-control form-control-sm" type="date"
                       id="txtFechaVencimiento" placeholder="dd/mm/yyyy" />
            </div>
            <div class="col-md-2 d-none" id="panelCodAduana">
                <label class="form-label">Cód. Aduana</label>
                <select class="form-select form-select-sm"
                        id="ddlCodigoAduana" disabled></select>
            </div>
            <div class="col-md-2 d-none" id="panelAnoAduana">
                <label class="form-label">Año DUA</label>
                <input class="form-control form-control-sm text-end" type="text"
                       id="txtAnoDua" maxlength="4" />
            </div>
        </div>

        <!-- Fila 6: RUC Beneficiario -->
        <div class="row g-2 mb-2">
            <div class="col-md-2">
                <label class="form-label">RUC Beneficiario</label>
                <div class="input-group input-group-sm">
                    <input class="form-control" type="text" id="txtRucBenef" readonly />
                    <button class="btn btn-outline-secondary" type="button"
                            id="btnBuscarRucBenef" disabled>
                        ...
                    </button>
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtRazonSocialBenef" readonly />
            </div>
        </div>

        <!-- Fila 7: Observación -->
        <div class="row g-2 mb-2">
            <div class="col-md-12">
                <label class="form-label">Observación</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtObservacion" readonly />
            </div>
        </div>

        <!-- Fila 8: Orden Compra, Fact. Múltiples -->
        <div class="row g-2 mb-2">
            <div class="col-md-3 d-none" id="divOrdenCompra">
                <label class="form-label">Orden de Compra</label>
                <div class="input-group input-group-sm">
                    <input class="form-control" type="text" id="txtOrdenCompra" readonly />
                    <button class="btn btn-outline-secondary" type="button"
                            id="btnBuscarOrdenCompra" disabled>
                        ...
                    </button>
                </div>
            </div>
            <div class="col-md-2 d-none" id="divTipoOrden">
                <label class="form-label">Tipo Orden</label>
                <select class="form-select form-select-sm"
                        id="ddlTipoOrden" disabled></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Fact. Múltiples</label>
                <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="chkFactMultiple" />
                </div>
            </div>
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════════
     SECCIÓN: Documento Asociado
══════════════════════════════════════════ -->
<div class="seccion-panel">
    <div class="seccion-header">
        <strong>Documento Asociado</strong>
    </div>
    <div class="seccion-body">
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Tipo Comprobante</label>
                <select class="form-select form-select-sm"
                        id="ddlTipoDocumentoAsociado" disabled></select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Serie</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtSerieAsociado" readonly maxlength="20" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Número</label>
                <div class="input-group input-group-sm">
                    <input class="form-control" type="text"
                           id="txtNumeroAsociado" readonly maxlength="20" />
                    <button class="btn btn-outline-secondary" type="button"
                            id="btnBuscarDocumentoAsociado" disabled>
                        ...
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     SECCIÓN: Detracción
══════════════════════════════════════════ -->
<div class="seccion-panel">
    <div class="seccion-header">
        <strong>Detracción</strong>
    </div>
    <div class="seccion-body">
        <div class="row g-2 mb-2">
            <div class="col-md-3">
                <label class="form-label">¿Tiene Detracción?</label>
                <div class="d-flex gap-3 mt-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               id="TieneDetraccion" disabled />
                        <label class="form-check-label" for="TieneDetraccion">Sí</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               id="NoTieneDetraccion" checked disabled />
                        <label class="form-check-label" for="NoTieneDetraccion">No</label>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label">Tipo Detracción</label>
                <select class="form-select form-select-sm"
                        id="ddlTipoDetraccion" disabled></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Porcentaje</label>
                <input class="form-control form-control-sm text-end" type="text"
                       id="txtPorcentajeDetraccion" readonly />
            </div>
            <div class="col-md-2">
                <label class="form-label">Constancia Depósito</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtConstanciaDeposito" readonly />
            </div>
            <div class="col-md-2">
                <label class="form-label">Fecha Depósito</label>
                <input class="form-control form-control-sm" type="date"
                       id="txtFechaDeposito" placeholder="dd/mm/yyyy" disabled />
            </div>
            <div class="col-md-2 d-none" id="ValorReferencial">
                <label class="form-label">Valor Referencial</label>
                <input class="form-control form-control-sm text-end monto" type="text"
                       id="txtValorReferencial" readonly />
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     SECCIÓN: Detalle Montos
══════════════════════════════════════════ -->
<div class="seccion-panel">
    <div class="seccion-header">
        <strong>Detalle Montos</strong>
    </div>
    <div class="seccion-body">

        <!-- Campos hidden de control de montos -->
        <input type="hidden" id="txtAplicaValorAduana" />
        <input type="hidden" id="txtAplicaMontoNeto" />
        <input type="hidden" id="txtAplicaMontoExento" />
        <input type="hidden" id="txtAplicaMontoIGVCosto" />
        <input type="hidden" id="txtAplicaMontoAuxiliar1" />
        <input type="hidden" id="txtAplicaMontoIGCredito" />
        <input type="hidden" id="txtAplicaMontoTotal" />
        <input type="hidden" id="txtAplicaMontoRetencion" />
        <input type="hidden" id="txtAplicaMontoMultas" />
        <input type="hidden" id="txtAplicaMontoBruto" />

        <!-- Editar montos -->
        <div class="row mb-2">
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="chkEditaMontos" />
                    <label class="form-check-label" for="chkEditaMontos">
                        Editar montos
                    </label>
                </div>
            </div>
        </div>

        <!-- Montos dinámicos -->
        <div class="row g-2">
            <div class="col-md-2 d-none" id="MontoNeto">
                <input type="hidden" id="txtMontoNetoCampo" />
                <input type="hidden" id="txtMontoNetoCalculo" />
                <input type="hidden" id="txtMontoNetoIndDetalle" />
                <input type="hidden" id="txtMontoNetoTipDes" />
                <label id="lblMontoNeto" class="form-label">Monto Neto</label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoNeto" readonly />
                </div>
            </div>
            <div class="col-md-2 d-none" id="MontoExento">
                <input type="hidden" id="txtMontoExentoCampo" />
                <input type="hidden" id="txtMontoExentoCalculo" />
                <input type="hidden" id="txtMontoExentoIndDetalle" />
                <input type="hidden" id="txtMontoExentoTipDes" />
                <label id="lblMontoExento" class="form-label">Exento</label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoExento" readonly />
                </div>
            </div>
            <div class="col-md-2 d-none" id="MontoSubtotal">
                <label class="form-label">Subtotal</label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end" type="text"
                           id="txtMontoSubtotal" readonly />
                </div>
            </div>
            <div class="col-md-3 d-none" id="MontoIGVCosto">
                <input type="hidden" id="txtMontoIGVCostoCampo" />
                <input type="hidden" id="txtMontoIGVCostoCalculo" />
                <input type="hidden" id="txtMontoIGVCostoIndDetalle" />
                <input type="hidden" id="txtMontoIGVCostoTipDes" />
                <label id="lblMontoIGVCosto" class="form-label"></label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end d-none" type="text"
                           id="txtMontoIGVCostoPorcentajeIGV" value="0.00" readonly />
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoIGVCosto" readonly />
                </div>
            </div>
            <div class="col-md-3 d-none" id="MontoIGVCredito">
                <input type="hidden" id="txtMontoIGVCreditoCampo" />
                <input type="hidden" id="txtMontoIGVCreditoCalculo" />
                <input type="hidden" id="txtMontoIGVCreditoIndDetalle" />
                <input type="hidden" id="txtMontoIGVCreditoTipDes" />
                <label id="lblMontoIGVCredito" class="form-label">IGV Créd. Fiscal</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text px-1">%</span>
                    <input class="form-control text-end" type="text" style="max-width:60px"
                           id="txtMontoIGVCreditoPorcentajeIGV" value="0.00" readonly />
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoIGVCredito" readonly />
                </div>
            </div>
            <div class="col-md-2 d-none" id="MontoTotal">
                <input type="hidden" id="txtMontoTotalCampo" />
                <input type="hidden" id="txtMontoTotalCalculo" />
                <input type="hidden" id="txtMontoTotalIndDetalle" />
                <input type="hidden" id="txtMontoTotalTipDes" />
                <label id="lblMontoTotal" class="form-label">Total</label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoTotal" readonly />
                </div>
            </div>
            <div class="col-md-2 d-none" id="MontoRetencion">
                <input type="hidden" id="txtMontoRetencionCampo" />
                <input type="hidden" id="txtMontoRetencionCalculo" />
                <input type="hidden" id="txtMontoRetencionIndDetalle" />
                <input type="hidden" id="txtMontoRetencionTipDes" />
                <label id="lblMontoRetencion" class="form-label">Retención</label>
                <div class="input-group input-group-sm">
                    <select class="form-select form-select-sm d-none"
                            id="ddlTipoRetencion" disabled></select>
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoRetencion" readonly />
                </div>
            </div>
            <div class="col-md-2 d-none" id="MontoBruto">
                <input type="hidden" id="txtMontoBrutoCampo" />
                <input type="hidden" id="txtMontoBrutoCalculo" />
                <input type="hidden" id="txtMontoBrutoIndDetalle" />
                <input type="hidden" id="txtMontoBrutoTipDes" />
                <label id="lblMontoBruto" class="form-label">Total a Pagar</label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoBruto" readonly />
                </div>
            </div>
            <div class="col-md-3 d-none" id="MontoMultas">
                <input type="hidden" id="txtMontoMultasCampo" />
                <input type="hidden" id="txtMontoMultasCalculo" />
                <input type="hidden" id="txtMontoMultasIndDetalle" />
                <input type="hidden" id="txtMontoMultasTipDes" />
                <label id="lblMontoMultas" class="form-label"></label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end d-none" type="text"
                           id="txtMontoMultasPorcentajeIGV" value="0.00" readonly />
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoMultas" readonly />
                </div>
            </div>
            <div class="col-md-3 d-none" id="ValorAduana">
                <input type="hidden" id="txtValorAduanaCampo" />
                <input type="hidden" id="txtValorAduanaCalculo" />
                <input type="hidden" id="txtValorAduanaIndDetalle" />
                <input type="hidden" id="txtValorAduanaTipDes" />
                <label id="lblValorAduana" class="form-label"></label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end d-none" type="text"
                           id="txtValorAduanaPorcentajeIGV" value="0.00" readonly />
                    <input class="form-control text-end monto" type="text"
                           id="txtValorAduana" readonly />
                </div>
            </div>
            <div class="col-md-3 d-none" id="MontoAuxiliar1">
                <input type="hidden" id="txtMontoAuxiliar1Campo" />
                <input type="hidden" id="txtMontoAuxiliar1Calculo" />
                <input type="hidden" id="txtMontoAuxiliar1IndDetalle" />
                <input type="hidden" id="txtMontoAuxiliar1TipDes" />
                <label id="lblMontoAuxiliar1" class="form-label"></label>
                <div class="input-group input-group-sm">
                    <input class="form-control text-end d-none" type="text"
                           id="txtMontoAuxiliar1PorcentajeIGV" value="0.00" readonly />
                    <input class="form-control text-end monto" type="text"
                           id="txtMontoAuxiliar1" readonly />
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     SECCIÓN: Estado
══════════════════════════════════════════ -->
<div class="seccion-panel">
    <div class="seccion-header">
        <strong>Estado</strong>
    </div>
    <div class="seccion-body">
        <div class="row g-2 mb-2">
            <div class="col-md-3">
                <label class="form-label">Digitador</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtRolDigitacion" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Digitación</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtFechaDigitacion" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label">Autorizador</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtRolAutorizacion" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Autorización</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtFechaAutorizacion" readonly />
            </div>
        </div>
        <div class="row g-2 mb-2">
            <div class="col-md-3">
                <label class="form-label">Aprobador</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtRolAprobacion" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Aprobación</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtFechaAprobacion" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtEstadoComprobante" readonly />
            </div>
        </div>
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Anulado por</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtRolAnulacion" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Anulación</label>
                <input class="form-control form-control-sm" type="text"
                       id="txtFechaAnulacion" readonly />
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     SECCIÓN: Información
══════════════════════════════════════════ -->
<div class="seccion-panel">
    <div class="seccion-header">
        <strong>Información</strong>
    </div>
    <div class="seccion-body">
        <textarea rows="4" class="form-control form-control-sm"
                  id="txtMensaje" readonly></textarea>
    </div>
</div>

<!-- Loading -->
<div id="imgCargandoComprobante"
     style="display:none; position:absolute; top:50%; left:50%; z-index:999">
    <div class="spinner-border text-primary" role="status"></div>
</div>